# ── Core ──────────────────────────────────────────────────────────────────────
FLASK_ENV=development
SECRET_KEY=dev-secret-key-change-this-in-production

# SQLite for local dev; PostgreSQL URI for production (set by Render automatically)
DATABASE_URL=sqlite:///instance/trade_tutor.db

# URL of the React frontend — added to CORS allowed origins
FRONTEND_URL=http://localhost:5173

# ── Stripe ────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Get from Stripe Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Create products + prices in Stripe Dashboard, then paste the price_... IDs here
STRIPE_PRICE_STARTER_MONTHLY=price_...
STRIPE_PRICE_STARTER_YEARLY=price_...
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...

# ── OpenAI (RTT AI coaching — optional) ───────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── PayPal (optional) ─────────────────────────────────────────────────────────
PAYPAL_CLIENT_ID=your_client_id_here
PAYPAL_SECRET=your_secret_here
PAYPAL_WEBHOOK_ID=your_webhook_id_here

# Use sandbox for testing; switch to https://api-m.paypal.com for production
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com

# Create subscription plans in PayPal Developer Dashboard, paste Plan IDs here
PAYPAL_PLAN_STARTER_MONTHLY=P-XXXXXXXXXXXXXXXXXXXX
PAYPAL_PLAN_STARTER_YEARLY=P-XXXXXXXXXXXXXXXXXXXX
PAYPAL_PLAN_PRO_MONTHLY=P-XXXXXXXXXXXXXXXXXXXX
PAYPAL_PLAN_PRO_YEARLY=P-XXXXXXXXXXXXXXXXXXXX

# ── Production tweaks (optional) ──────────────────────────────────────────────
# Redis URL for rate-limiter (defaults to in-memory if not set)
# RATELIMIT_STORAGE_URL=redis://localhost:6379

# Override number of Gunicorn workers (default: min(CPU*2+1, 4))
# WEB_CONCURRENCY=2
